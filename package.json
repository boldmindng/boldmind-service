{
  "name": "@boldmindng/service",
  "version": "2.0.1",
  "private": true,
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "rimraf tsconfig.tsbuildinfo && nest build",
    "dev": "node -e \"try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && nest start --watch",
    "dev:debug": "node -e \"try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && nest start --debug --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
