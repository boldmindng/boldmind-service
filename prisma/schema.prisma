  weeklyGoalDays         Int       @default(5)
  xpPoints               Int       @default(0)
  level                  Int       @default(1)
  totalSessionsDone      Int       @default(0)
  totalQuestionsAnswered Int       @default(0)
  totalCorrect           Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_streaks")
}

/// Subject-level performance analytics (aggregated, updated after each session)
model SubjectPerformance {
  id             String    @id @default(cuid())
  userId         String
  examType       ExamType
  subject        String
  totalAttempted Int       @default(0)
  totalCorrect   Int       @default(0)
  averagePercent Float     @default(0)
  lastAttemptAt  DateTime?
  weakTopics     String[]  @default([]) // Topics that need improvement
  strongTopics   String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

