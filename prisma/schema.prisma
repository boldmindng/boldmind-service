generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CRMStage {
  NEW
  CONTACTED
  PROPOSAL
  WON
  LOST
}

enum ScheduledPostStatus {
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum SystemRole {
  super_admin
  admin
  manager
  editor
  support
  analyst
}

enum EcosystemRole {
  hustler
  founder
  creator
  student
  business_owner
  operator
  partner
  vibe_coder
}

enum UserRole {
  super_admin
  admin
  manager
  editor
  support
  analyst
  hustler
  founder
  creator
  student
  vibe_coder
  business_owner
  operator
  partner
  guest
}

enum AuthProvider {
  email
  google
  github
  twitter
  facebook
}

enum DigitalMaturity {
  low
  medium
  high
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
  PAST_DUE
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  ABANDONED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  MANUAL
}

enum NotificationType {
  EMAIL
  WHATSAPP
  PUSH
  IN_APP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum MediaProvider {
  CLOUDFLARE_R2
  CLOUDINARY
  LOCAL
}

enum ExamType {
  JAMB
  WAEC
  NECO
  GCE
  POST_UTME
  SKILL_TEST
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CBTSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIMED_OUT
}

enum PlanAIJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PlanAIJobType {
  BUSINESS_PLAN
  PITCH_DECK
  FINANCIAL_FORECAST
  BRANDING_PACKAGE
  CREDIBILITY_HUB
  INVESTOR_DECK
  MARKETING_CAMPAIGN
  ANALYTICS_REPORT
  EMAIL_SCRAPE
  STOREFRONT_SETUP
  HR_DOCS
  LEGAL
  OPERATIONS_DOC
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ESCALATED
  SPAM
}

enum MessagePlatform {
  WHATSAPP
  INSTAGRAM_DM
  INSTAGRAM_COMMENT
  FACEBOOK_MESSAGE
  FACEBOOK_COMMENT
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  ENDURANCE
  FLEXIBILITY
  MAINTENANCE
  MAINTAIN
  GENERAL_WELLNESS
}

enum WorkoutType {
  HIIT
  STRENGTH
  CARDIO
  YOGA
  PILATES
  OUTDOOR
  HOME_WORKOUT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StoreStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum WaitlistStatus {
  PENDING
  APPROVED
  INVITED
  CONVERTED
  REJECTED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH MODULE
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String? @unique
  passwordHash String? // nullable — OAuth users may have no password
  name         String

  role            UserRole        @default(guest)
  ecosystemRole   EcosystemRole? // Secondary persona layer
  digitalMaturity DigitalMaturity @default(low)

  permissions String[] @default([])

  isVerified       Boolean   @default(false)
  isActive         Boolean   @default(true)
  isBanned         Boolean   @default(false)
  banReason        String?
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isPhoneVerified  Boolean   @default(false)

  // OAuth
  provider   AuthProvider @default(email)
  providerId String? // Google sub / GitHub id / etc.

  // Session metadata
  lastLoginAt DateTime?
  lastLoginIp String?

  avatar String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile            UserProfile?
  refreshTokens      RefreshToken[]
  otpVerifications   OTPVerification[]
  subscriptions      Subscription[]
  payments           Payment[]
  invoices           Invoice[]
  notifications      NotificationLog[]
  inAppNotifications Notification[]
  pushSubscriptions  PushSubscription[]
  mediaFiles         MediaFile[]
  mediaUploads       Media[]
  activityLogs       ActivityLog[]
  analyticsEvents    AnalyticsEvent[]

  // ViralKit
  generatedContents GeneratedContent[]
  usageRecords      UsageRecord[]

  // EduCenter
  cbtSessions       CBTSession[]
  studyProgress     StudentProgress[]
  studyStreak       StudyStreak?
  courseEnrollments CourseEnrollment[]

  // PlanAI
  planAIJobs      PlanAIJob[]
  planAITemplates PlanAITemplate[]

  // Receptionist
  receptionistClient ReceptionistClient?

  // Fitness
  fitnessProfile FitnessProfile?
  fitnessStreak  FitnessStreak?
  workoutPlans   WorkoutPlan[]
  workoutLogs    WorkoutLog[]
  mealLogs       MealLog[]
  bodyMetricLogs BodyMetricLog[]

  // OS
  osProfile        OSProfile?
  memberships      WorkspaceMember[]
  createdTasks     Task[]            @relation("TaskCreator")
  assignedTasks    Task[]            @relation("TaskAssignee")
  createdProjects  Project[]
  pomodoroSessions PomodoroSession[]
  knowledgeNodes   KnowledgeNode[]

  // Storefronts
  stores Store[]
  orders Order[] @relation("BuyerOrders")

  // Admin
  adminLogs            AdminLog[]
  waitlistEntries      WaitlistEntry[]
  crmcontacts          CRMContact[]
  wallet               Wallet?
  apiKeys              ApiKey[]
  school               School?
  referralsMade        Referral[]            @relation("Referrer")
  referredBy           Referral?             @relation("Referred")
  affiliateEarnings    AffiliateEarning[]
  webhookSubscriptions WebhookSubscription[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([ecosystemRole])
  @@index([provider, providerId])
  @@index([isActive])
  @@map("users")
}

// ─── WALLET ──────────────────────────────────────────────────────────────────

model Wallet {
  id             String         @id @default(cuid())
  userId         String         @unique
  balanceKobo    Int            @default(0)
  tier           WalletTier     @default(TIER1)
  dailyDebitKobo Int            @default(0)
  lastDebitReset DateTime       @default(now())
  isLocked       Boolean        @default(false)
  lockReason     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger         WalletLedger[]

  @@map("wallets")
}

model WalletLedger {
  id           String          @id @default(cuid())
  walletId     String
  type         WalletEntryType
  amountKobo   Int
  balanceAfter Int
  description  String
  reference    String?
  source       WalletSource
  metadata     Json?
  createdAt    DateTime        @default(now())
  wallet       Wallet          @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([walletId, createdAt])
  @@index([reference])
  @@map("wallet_ledger")
}

enum WalletTier {
  TIER1
  TIER2
}

enum WalletEntryType {
  CREDIT
  DEBIT
}

enum WalletSource {
  REFERRAL_COMMISSION
  AFFILIATE_EARNING
  SUBSCRIPTION_REFUND
  ADMIN_CREDIT
  PROMOTIONAL_BONUS
  MARKETPLACE_PAYOUT
  SUBSCRIPTION_PAYMENT
  MARKETPLACE_PURCHASE
  WITHDRAWAL
}

// ─── REFERRALS ────────────────────────────────────────────────────────────────

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredId     String   @unique
  productSlug    String
  status         String   @default("pending") // pending | converted | paid
  commissionKobo Int      @default(0)
  createdAt      DateTime @default(now())
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id])
  referred       User     @relation("Referred", fields: [referredId], references: [id])

  @@index([referrerId])
  @@map("referrals")
}

model AffiliateEarning {
  id         String    @id @default(cuid())
  userId     String
  source     String
  amountKobo Int
  reference  String?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("affiliate_earnings")
}

// ─── API KEYS ─────────────────────────────────────────────────────────────────

model ApiKey {
  id         String                @id @default(cuid())
  userId     String
  name       String
  keyHash    String                @unique
  prefix     String
  scopes     String[]
  tier       ApiTier               @default(STARTER)
  isActive   Boolean               @default(true)
  rateLimit  Int                   @default(1000)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User                  @relation(fields: [userId], references: [id])
  webhooks   WebhookSubscription[]

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

enum ApiTier {
  STARTER
  GROWTH
  ENTERPRISE
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  userId    String
  apiKeyId  String
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])

  @@index([userId])
  @@map("webhook_subscriptions")
}

// ─── SCHOOL ───────────────────────────────────────────────────────────────────

model School {
  id              String    @id @default(cuid())
  name            String
  state           String
  address         String?
  contactEmail    String
  adminUserId     String    @unique
  plan            String    @default("basic")
  studentSlots    Int       @default(50)
  usedSlots       Int       @default(0)
  payingUntil     DateTime?
  paystackSubCode String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  admin           User      @relation(fields: [adminUserId], references: [id])

  @@map("schools")
}

// ─── VIBE CODERS CLASSROOM ───────────────────────────────────────────────────

model VibeCoderProjectSubmission {
  id          String             @id @default(cuid())
  applicantId String
  moduleId    String
  githubUrl   String?
  loomUrl     String?
  brief       String             @db.Text
  status      String             @default("submitted")
  mentorNote  String?            @db.Text
  reviewedBy  String?
  score       Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  applicant   VibeCoderApplicant @relation(fields: [applicantId], references: [id])

  @@index([applicantId])
  @@map("vc_project_submissions")
}

model VibeCoderAttendance {
  id          String             @id @default(cuid())
  applicantId String
  sessionDate DateTime
  sessionType String
  moduleId    String
  attended    Boolean            @default(false)
  joinedAt    DateTime?
  duration    Int?
  createdAt   DateTime           @default(now())
  applicant   VibeCoderApplicant @relation(fields: [applicantId], references: [id])

  @@unique([applicantId, sessionDate, moduleId])
  @@map("vc_attendance")
}

// ── CRM ──────────────────────────────────────────────────────────────────────

model CRMContact {
  id           String    @id @default(cuid())
  userId       String
  name         String
  email        String?
  phone        String?
  whatsapp     String?
  company      String?
  source       String?
  tags         String[]
  stage        CRMStage  @default(NEW)
  dealValueNGN Int?
  lastContact  DateTime?
  notes        String?   @db.Text
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions CRMInteraction[]

  @@index([userId])
  @@index([userId, stage])
  @@index([email])
  @@index([phone])
  @@map("crm_contacts")
}

model CRMInteraction {
  id        String   @id @default(cuid())
  contactId String
  userId    String
  type      String // call | email | whatsapp | meeting | note
  content   String   @db.Text
  direction String? // inbound | outbound
  createdAt DateTime @default(now())

  contact CRMContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId, createdAt])
  @@map("crm_interactions")
}

// ── HR & PAYROLL ─────────────────────────────────────────────────────────────

model HREmployee {
  id          String         @id @default(cuid())
  businessId  String // owner's userId
  fullName    String
  email       String
  phone       String?
  department  String?
  role        String
  salaryNGN   Int // monthly gross in kobo
  startDate   DateTime
  bankName    String?
  bankAccount String?
  pensionPin  String?
  taxId       String?
  status      EmployeeStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  payslips      Payslip[]
  leaveRequests LeaveRequest[]

  @@index([businessId])
  @@index([businessId, status])
  @@map("hr_employees")
}

model Payslip {
  id         String    @id @default(cuid())
  employeeId String
  month      Int
  year       Int
  grossNGN   Int
  payeNGN    Int
  pensionNGN Int
  nhfNGN     Int
  netNGN     Int
  pdfUrl     String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  employee HREmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("payslips")
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  type       String // annual | sick | maternity | paternity | unpaid
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())

  employee HREmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

// ── SOCIAL MEDIA ─────────────────────────────────────────────────────────────

model SocialMediaAccount {
  id           String    @id @default(cuid())
  userId       String
  platform     String // instagram | facebook | tiktok | twitter | linkedin | youtube | threads | bluesky
  accountId    String
  accountName  String
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?
  pageId       String?
  connected    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scheduledPosts ScheduledPost[]

  @@unique([userId, platform, accountId])
  @@index([userId])
  @@map("social_media_accounts")
}

model ScheduledPost {
  id           String              @id @default(cuid())
  userId       String
  accountId    String
  platforms    String[]
  content      String              @db.Text
  mediaUrls    String[]
  scheduledFor DateTime
  timezone     String              @default("Africa/Lagos")
  status       ScheduledPostStatus @default(QUEUED)
  publishedAt  DateTime?
  errorMsg     String?
  bullJobId    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  account SocialMediaAccount @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
  @@map("scheduled_posts")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  family     String // Token family for rotation detection
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OTPVerification {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  code      String // bcrypt hashed
  purpose   String // "email_verify" | "phone_verify" | "password_reset" | "2fa"
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([phone, purpose])
  @@index([code])
  @@index([expiresAt])
  @@map("otp_verifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER MODULE
// ─────────────────────────────────────────────────────────────────────────────

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String?
  bio            String?  @db.Text
  avatarUrl      String?
  coverImageUrl  String?
  website        String?
  location       String?
  state          String? // Nigerian state
  timezone       String   @default("Africa/Lagos")
  language       String   @default("en")
  prefersPidgin  Boolean  @default(false)
  dyslexiaMode   Boolean  @default(false)
  activeProducts String[] @default([])
  onboardingDone Boolean  @default(false)
  referralCode   String   @unique @default(cuid())
  referredBy     String?

  // EduCenter specific
  examTarget  ExamType? // What exam the student is preparing for
  targetYear  Int? // Year of exam (e.g., 2026)
  targetScore Int? // e.g., 280 for JAMB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@map("user_profiles")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  resource    String?
  productSlug String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([productSlug])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  productSlug        String
  planName           String             @default("Plan")
  amountNGN          Int                @default(0)
  interval           String             @default("monthly")
  tier               SubscriptionTier   @default(FREE)
  status             SubscriptionStatus @default(TRIAL)
  paystackSubCode    String?            @unique
  planCode           String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  cancelReason       String?
  trialEndsAt        DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([userId, productSlug])
  @@index([userId])
  @@index([productSlug])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Payment {
  id             String          @id @default(cuid())
  userId         String
  subscriptionId String?
  provider       PaymentProvider @default(PAYSTACK)
  paystackRef    String          @unique
  paystackTrxRef String?         @unique
  paystackId     String?         @unique
  amountNGN      Int // Kobo
  currency       String          @default("NGN")
  status         PaymentStatus   @default(PENDING)
  productSlug    String
  description    String?
  channel        String?
  metadata       Json?
  webhookPayload Json?
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?

  @@index([userId])
  @@index([paystackRef])
  @@index([status])
  @@index([productSlug])
  @@index([createdAt])
  @@map("payments")
}

model Invoice {
  id             String    @id @default(cuid())
  userId         String
  paymentId      String    @unique
  invoiceNumber  String    @unique
  amount         Int
  currency       String    @default("NGN")
  vatAmount      Int       @default(0)
  totalAmount    Int
  dueDate        DateTime?
  paidAt         DateTime?
  pdfUrl         String?
  lineItems      Json
  billingAddress Json?
  createdAt      DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([userId])
  @@index([invoiceNumber])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION MODULE
// ─────────────────────────────────────────────────────────────────────────────

model NotificationLog {
  id         String             @id @default(cuid())
  userId     String
  type       NotificationType
  status     NotificationStatus @default(PENDING)
  subject    String?
  body       String             @db.Text
  recipient  String
  metadata   Json?
  sentAt     DateTime?
  readAt     DateTime?
  failReason String?
  retryCount Int                @default(0)
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, status])
  @@index([createdAt])
  @@map("notification_logs")
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String?
  auth        String?
  keys        Json?
  userAgent   String?
  deviceLabel String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — IN-APP
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  meta      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDIA MODULE
// ─────────────────────────────────────────────────────────────────────────────

model MediaFile {
  id          String        @id @default(cuid())
  userId      String
  key         String        @unique
  url         String
  cdnUrl      String?
  type        MediaType
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  duration    Float?
  altText     String?
  caption     String?
  productSlug String?
  isPublic    Boolean       @default(true)
  provider    MediaProvider @default(CLOUDFLARE_R2)
  metadata    Json?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([productSlug])
  @@index([type])
  @@map("media_files")
}

/// Media upload tracking (R2 storage)
model Media {
  id           String   @id @default(cuid())
  key          String   @unique
  url          String
  folder       String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([folder])
  @@map("media_uploads")
}

model CBTSession {
  id             String           @id @default(cuid())
  userId         String
  examType       ExamType
  subject        String // "Mathematics", "English Language", etc.
  year           Int? // Optional: specific year filter for questions
  totalQuestions Int
  timeLimitSecs  Int // e.g. 1800 for 30 min
  status         CBTSessionStatus @default(IN_PROGRESS)

  questionIds String[] // ALOC API question IDs

  // Results — computed at session completion
  score         Int? // Number correct
  percentage    Float? // score / totalQuestions * 100
  timeTakenSecs Int?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers StudentProgress[]

  @@index([userId])
  @@index([userId, examType, subject])
  @@index([status])
  @@index([startedAt])
  @@map("cbt_sessions")
}

model StudentProgress {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  examType  ExamType
  subject   String

  // External ALOC API reference (not a DB relation)
  alocQuestionId String // ALOC API question ID

  selectedAnswer String // "A" | "B" | "C" | "D"
  correctAnswer  String // Stored at answer time from ALOC response
  isCorrect      Boolean
  timeTakenSecs  Int     @default(0)
  isSkipped      Boolean @default(false)

  // Store the question text snapshot for review (avoids re-fetching)
  questionSnapshot Json? // { question, options, explanation } from ALOC

  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  session CBTSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([userId, examType, subject])
  @@index([alocQuestionId])
  @@map("student_progress")
}

/// Gamification — study streak and XP
model StudyStreak {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  currentStreak          Int       @default(0)
  longestStreak          Int       @default(0)
  totalDaysStudied       Int       @default(0)
