// ─────────────────────────────────────────────────────────────────────────────
// VIBE CODERS MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum VibeCoderStatus {
  APPLIED // Step 1 submitted — gets WhatsApp community link immediately
  SHORTLISTED // Admin shortlisted → assessment token email sent
  ASSESSED // Step 2 (deep psychology) submitted
  ACCEPTED // Admin accepted → payment link sent
  ENROLLED // Payment confirmed — full cohort access
  REJECTED
  WITHDRAWN
}

model VibeCoderCohort {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  status              String   @default("upcoming") // open | closed | upcoming | active | completed
  startDate           DateTime
  endDate             DateTime
  applicationDeadline DateTime
  capacity            Int      @default(30)
  enrolledCount       Int      @default(0)
  priceMin            Int // in NGN kobo
  priceMax            Int // in NGN kobo
  description         String?  @db.Text

  applicants VibeCoderApplicant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vibecoders_cohorts")
}

model VibeCoderApplicant {
  id String @id @default(cuid())

  // Step 1 — interest form
  name       String
  email      String @unique
  whatsapp   String
  archetype  String // dreamer | professionaliser | rural_builder | career_switcher
  idea       String @db.Text
  obstacle   String
  commitment String

  // Pipeline status
  status VibeCoderStatus @default(APPLIED)

  // Step 2 — assessment (only after shortlisting)
  assessmentToken  String?   @unique
  assessmentExpiry DateTime?
  assessmentData   Json? // raw answers keyed by question id
  assessmentScore  Json? // AI-scored dimensions {mindset, clarity, learning, community, overall}
  assessedAt       DateTime?

  // Enrollment
  cohortId    String?
  paymentPath String? // one_time | installment | isa | scholarship
  paystackRef String?
  enrolledAt  DateTime?

  // Admin
  adminNotes   String? @db.Text
  source       String?
  referralCode String?

  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  projectSubmissions VibeCoderProjectSubmission[]
  attendance         VibeCoderAttendance[]
  cohort             VibeCoderCohort?             @relation(fields: [cohortId], references: [id])

  @@index([status])
  @@index([cohortId])
  @@index([email])
  @@map("vibecoders_applicants")
}

// ─────────────────────────────────────────────────────────────────────────────
// SAFEAI MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum IncidentType {
  THEFT
  ROBBERY
  BURGLARY
