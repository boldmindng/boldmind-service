  @@index([userId])
  @@map("subject_performances")
}

/// Course content — stored in our DB (not ALOC)
model Course {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  description     String             @db.Text
  category        String // "digital-skills", "marketing", "ai-tools", "exam-prep"
  examType        ExamType? // null for non-exam courses
  subject         String?
  thumbnailUrl    String?
  videoUrl        String? // Cloudflare Stream URL
